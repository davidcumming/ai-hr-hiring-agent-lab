# ============================================================================
# Source-controlled SAMPLE environment file — PLACEHOLDERS ONLY, NO SECRETS.
# The lab default is fully local/deterministic: with this file unused (or
# copied verbatim), live AI/Foundry paths stay disabled and Azure Blob storage
# remains opt-in via the storage-specific gate below.
# Foundry/model wiring is human-gated (deferred Foundry ADR + BQ-005 region
# approval).
# ============================================================================

# Foundry/model live switch: anything other than "true" keeps live AI paths
# disabled. Azure Blob storage uses HRHA_ENABLE_AZURE_STORAGE below.
HRHA_ENABLE_LIVE_AZURE=false

# Hard block on Foundry providers, independent of everything else.
HRHA_PROVIDER_KILL_SWITCH=false

# Azure Storage placeholders. The normal local app ignores these; the Azure
# Functions wrapper overlays them only when HRHA_STORAGE_BACKEND=azure_blob.
HRHA_STORAGE_BACKEND=
HRHA_ENABLE_AZURE_STORAGE=false
HRHA_STORAGE_ACCOUNT_URL=
HRHA_STORAGE_CONTAINER=
# Table/Queue endpoint placeholders for guarded E8 workflow-storage checks.
HRHA_STORAGE_TABLE_ENDPOINT=
HRHA_STORAGE_QUEUE_ENDPOINT=

# E8 workflow storage placeholders. The normal local app ignores these; the
# Azure Functions wrapper overlays them only when HRHA_WORKFLOW_STORAGE_BACKEND=azure.
HRHA_WORKFLOW_STORAGE_BACKEND=
HRHA_ENABLE_AZURE_WORKFLOW_STORAGE=false
HRHA_WORKFLOW_BLOB_CONTAINER=
HRHA_WORKFLOW_TABLE_PREFIX=
HRHA_WORKFLOW_QUEUE_NAME=

# Foundry placeholders (provider scaffolds fail closed regardless):
HRHA_FOUNDRY_PROJECT_ENDPOINT=
HRHA_FOUNDRY_MODEL_DEPLOYMENT=
HRHA_FOUNDRY_AGENT_ID_PREFIX=

# Identity placeholder (managed identity client id at the wiring slice):
HRHA_MANAGED_IDENTITY_CLIENT_ID=
