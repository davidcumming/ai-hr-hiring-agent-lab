# ============================================================================
# PLACEHOLDER app settings / environment variables — NO live values, NO secrets.
# Mirrors config/azure.env.sample. Live wiring is human-gated (deferred ADR +
# BQ-005). Identity-based auth only — no keys, connection strings, SAS tokens.
# ============================================================================

# --- Guards (server-side only; the lab default keeps everything local) ---
HRHA_ENABLE_LIVE_AZURE=false
HRHA_PROVIDER_KILL_SWITCH=false

# --- Storage placeholders. The normal local app ignores these; function_app.py
#     overlays them only when HRHA_STORAGE_BACKEND=azure_blob. ---
HRHA_STORAGE_BACKEND=
HRHA_ENABLE_AZURE_STORAGE=false
HRHA_STORAGE_ACCOUNT_URL=            # e.g. https://<storage-account>.blob.core.windows.net
HRHA_STORAGE_CONTAINER=              # e.g. hrha-evaluations
HRHA_STORAGE_TABLE_ENDPOINT=         # e.g. https://<storage-account>.table.core.windows.net
HRHA_STORAGE_QUEUE_ENDPOINT=         # e.g. https://<storage-account>.queue.core.windows.net

# --- E8 workflow storage placeholders. The normal local app ignores these;
#     function_app.py overlays them only when HRHA_WORKFLOW_STORAGE_BACKEND=azure. ---
HRHA_WORKFLOW_STORAGE_BACKEND=
HRHA_ENABLE_AZURE_WORKFLOW_STORAGE=false
HRHA_WORKFLOW_BLOB_CONTAINER=        # optional; defaults to HRHA_STORAGE_CONTAINER
HRHA_WORKFLOW_TABLE_PREFIX=          # optional alphanumeric prefix
HRHA_WORKFLOW_QUEUE_NAME=            # e.g. hrha-workflow-smoke

# --- Foundry placeholders (runtime shape = deferred ADR decision) ---
HRHA_FOUNDRY_PROJECT_ENDPOINT=       # e.g. https://<foundry-resource>.services.ai.azure.com/api/projects/<project>
HRHA_FOUNDRY_MODEL_DEPLOYMENT=       # model deployment name (foundry_project_responses shape)
HRHA_FOUNDRY_AGENT_ID_PREFIX=        # agent id/prefix (foundry_prompt_agent / foundry_hosted_agent shapes)

# --- Identity placeholders ---
HRHA_MANAGED_IDENTITY_CLIENT_ID=     # user-assigned managed identity client id (wiring slice)
